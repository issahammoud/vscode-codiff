{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["vscode", "node"]
  },
  "include": ["src/extension.ts", "src/diffPanel.ts"],
  "exclude": ["node_modules", "dist", "src/webview"]
}
